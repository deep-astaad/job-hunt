# Internal URL to Django (used by Next.js server-side proxy, NOT exposed to browser)
BACKEND_INTERNAL_URL=http://django:8000

# Shared secret so the Next.js proxy is recognized by Django as an internal caller
# (optional — only needed if you add internal-token auth to Django)
INTERNAL_API_TOKEN=change-me-in-production

# Base path the app is served at (must match next.config.ts basePath)
NEXT_PUBLIC_BASE_PATH=/v2
